# AI provider configuration for the lesson-generation pipeline.
# Copy this file to ".env" and fill in real values to enable OpenAI-backed generation.
# With no OPENAI_API_KEY set, the app falls back to the deterministic mock service.

# Postgres connection string (Vercel Postgres / Neon). Required for the app to run.
# Use the direct/unpooled connection string so `prisma db push` works.
DATABASE_URL=

# Vercel Blob token. Set automatically by Vercel when you add Blob storage.
# When present, generated panel art is uploaded to Blob instead of the local disk.
BLOB_READ_WRITE_TOKEN=

# Force a provider explicitly: "openai" or "mock".
# Leave unset to auto-select (openai when a key is present, otherwise mock).
# AI_PROVIDER=openai

# OpenAI API key. Presence of this key enables real text generation.
OPENAI_API_KEY=

# Render real manga panel art with gpt-image-1 during generation.
# Costs money per panel (~6 images per lesson), so it is OFF by default.
# Requires OPENAI_API_KEY. Set to "true" to enable.
GENERATE_IMAGES=false

# Optional model overrides.
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1536
